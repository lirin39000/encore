.index {
  padding: 20rpx;
}

.status {
  display: block;
  padding: 80rpx 0;
  text-align: center;
  color: rgba(242, 236, 225, 0.62);
  font-size: 26rpx;
}

.card {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.poster {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #2A211C;
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #F2ECE1;
}

.sub {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.75);
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E0664A;
}
