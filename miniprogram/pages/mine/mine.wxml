<view class="page">
  <view class="tabs">
    <view class="tab {{tab === 'artists' ? 'tab-active' : ''}}" data-tab="artists" bindtap="switchTab">关注艺人</view>
    <view class="tab {{tab === 'favorites' ? 'tab-active' : ''}}" data-tab="favorites" bindtap="switchTab">收藏的演出</view>
  </view>

  <view wx:if="{{tab === 'artists'}}" class="section">
    <view class="add-row">
      <input
        class="add-input"
        placeholder="搜索艺人名添加关注"
        value="{{addInput}}"
        bindinput="onAddInput"
        bindfocus="onAddInput"
      />
      <view class="add-btn" bindtap="addArtist">添加</view>
    </view>

    <view wx:if="{{showSuggestions && suggestions.length > 0}}" class="suggestions">
      <view wx:for="{{suggestions}}" wx:key="*this" class="suggestion-item" data-name="{{item}}" bindtap="addArtist">
        {{item}}
      </view>
    </view>

    <view class="hint">输入后等待几秒输入框下方可能检索到相关乐队/艺人，也可以直接手动输入完整乐队/艺人名称添加（注意用官方名称，比如 Chinese Football 不能添加成"国足"，否则可能查找不成功）</view>

    <view class="artist-list">
      <view wx:if="{{loadingArtists}}" class="status">加载中...</view>
      <view wx:elif="{{artists.length === 0}}" class="status">还没有关注的艺人</view>
      <view wx:for="{{artists}}" wx:key="_id" class="list-row">
        <view class="list-row-text"><text class="list-star">★</text> {{item.artist_name}}</view>
        <view class="remove-btn" data-id="{{item._id}}" bindtap="removeArtist">移除</view>
      </view>
    </view>
  </view>

  <view wx:if="{{tab === 'favorites'}}" class="section">
    <view wx:if="{{loadingFavorites}}" class="status">加载中...</view>
    <view wx:elif="{{favorites.length === 0}}" class="status">还没有收藏的演出</view>

    <view wx:for="{{favorites}}" wx:key="_id" class="card">
      <view class="card-blur" style="background-image:{{item.posterBg}};"></view>
      <view class="card-overlay"></view>

      <view class="card-info">
        <view class="card-title">{{item.title}}</view>
        <view class="card-row">
          <text class="card-star">★</text>
          <text class="card-performers">{{item.performersText}}</text>
        </view>
        <view class="card-sub">{{item.showTimeText}}</view>
        <view class="card-sub">{{item.site_name}} · {{item.city_name}}</view>
        <view class="card-bottom-row">
          <text class="card-price">{{item.price}}</text>
          <text class="card-detail-link" data-id="{{item.id}}" catchtap="copyDetailLink">查看详情 →</text>
        </view>
      </view>

      <view
        class="card-poster"
        style="background-image:{{item.posterBg}};"
        data-url="{{item.poster_url}}"
        bindtap="previewPoster"
      >
        <view wx:if="{{item.sold_out === 2}}" class="sold-out-badge">已售罄</view>
        <image class="heart-btn" src="{{item.heartIcon}}" data-show="{{item}}" catchtap="toggleFavorite" />
      </view>
    </view>
  </view>

  <view class="footer">有问题或建议欢迎反馈至 lirin3900@gmail.com ╮(╯▽╰)╭</view>
</view>
