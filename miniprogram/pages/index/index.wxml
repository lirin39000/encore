<view class="page">
  <view class="header-inner">
    <view class="header-row">
      <text class="logo">Live雷达</text>
    </view>

    <view class="search-wrap">
      <input
        class="search-input"
        placeholder="搜索艺人、场馆或演出"
        value="{{searchInput}}"
        bindinput="onSearchInput"
      />
    </view>

    <view class="toolbar">
      <view class="pill {{scope === 'followed' ? 'pill-active' : ''}}" bindtap="toggleScope">我关注的艺人</view>

      <view class="filter-anchor">
        <view class="pill filter-pill {{filterPanelOpen ? 'pill-active' : ''}}" bindtap="openFilterPanel">
          ☰ 筛选<block wx:if="{{activeFilterCount > 0}}"> ({{activeFilterCount}})</block>
        </view>

        <view
          wx:if="{{filterPanelOpen}}"
          class="filter-panel"
          style="left: {{-filterPanelShift}}px;"
        >
          <view class="filter-panel-body">
            <view class="filter-tabs">
              <view
                class="filter-tab {{filterTab === 'location' ? 'filter-tab-active' : ''}}"
                data-tab="location"
                bindtap="switchFilterTab"
              >位置</view>
              <view
                class="filter-tab {{filterTab === 'schedule' ? 'filter-tab-active' : ''}}"
                data-tab="schedule"
                bindtap="switchFilterTab"
              >档期</view>
              <view
                class="filter-tab {{filterTab === 'price' ? 'filter-tab-active' : ''}}"
                data-tab="price"
                bindtap="switchFilterTab"
              >价位</view>
            </view>

            <view class="filter-content">
              <block wx:if="{{filterTab === 'location'}}">
                <view class="filter-label">我的城市</view>
                <view class="city-chip-row">
                  <view wx:for="{{cityNames}}" wx:key="*this" class="chip">
                    {{item}}
                    <text class="chip-remove" data-name="{{item}}" catchtap="removeCity">✕</text>
                  </view>
                  <view class="add-city-circle" bindtap="openCityPicker">+</view>
                </view>
                <view wx:if="{{cityNames.length === 0}}" class="filter-hint">不限城市，点 + 添加</view>
              </block>

              <block wx:if="{{filterTab === 'schedule'}}">
                <view class="filter-label">每周有空的时间</view>
                <view class="weekday-row">
                  <view
                    wx:for="{{weekdayOptions}}"
                    wx:key="key"
                    class="weekday-circle {{item.active ? 'weekday-active' : ''}}"
                    data-day="{{item.key}}"
                    bindtap="toggleWeekday"
                  >
                    {{item.label}}
                  </view>
                </view>
              </block>

              <block wx:if="{{filterTab === 'price'}}">
                <view class="filter-label">预算上限 ¥{{maxPrice}}</view>
                <slider
                  min="50"
                  max="{{maxPriceCeiling}}"
                  step="10"
                  value="{{maxPrice}}"
                  bindchange="onPriceChange"
                  activeColor="#C4472E"
                  backgroundColor="rgba(255,255,255,0.14)"
                  block-size="16"
                />
              </block>
            </view>
          </view>

          <view class="filter-confirm" bindtap="closeFilterPanel">确定</view>
        </view>
      </view>

      <view class="pill sort-pill" bindtap="toggleSort">排序：{{sortBy === 'time' ? '时间' : '价格'}} ▾</view>
    </view>

    <view wx:if="{{filterPanelOpen}}" class="click-outside-mask" catchtap="closeFilterPanel"></view>

    <view wx:if="{{!loading}}" class="meta-row">
      <text class="total-text">共 {{total}} 场演出</text>
      <view wx:for="{{cityNames}}" wx:key="*this" class="meta-chip">
        <text>{{item}}</text>
        <text class="meta-chip-remove" data-name="{{item}}" bindtap="removeCity">✕</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="status">加载中...</view>
  <view wx:elif="{{error}}" class="status">{{error}}</view>
  <view wx:elif="{{shows.length === 0}}" class="status">暂无演出</view>

  <view wx:for="{{shows}}" wx:key="_id" class="card">
    <view class="card-blur" style="background-image:{{item.posterBg}};"></view>
    <view class="card-overlay"></view>

    <view class="card-info">
      <view class="card-title">{{item.title}}</view>
      <view class="card-row">
        <text class="card-star">★</text>
        <text class="card-performers">{{item.performersText}}</text>
      </view>
      <view class="card-sub">{{item.showTimeText}}</view>
      <view class="card-sub">{{item.site_name}} · {{item.city_name}}</view>
      <view class="card-bottom-row">
        <text class="card-price">{{item.price}}</text>
        <text class="card-detail-link" data-id="{{item.id}}" catchtap="copyDetailLink">查看详情 →</text>
      </view>
    </view>

    <view
      class="card-poster"
      style="background-image:{{item.posterBg}};"
      data-url="{{item.poster_url}}"
      bindtap="previewPoster"
    >
      <view wx:if="{{item.sold_out === 2}}" class="sold-out-badge">已售罄</view>
      <view class="heart-btn" data-show="{{item}}" catchtap="toggleFavorite">
        <image class="heart-icon" src="{{item.heartIcon}}" />
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="status">加载中...</view>
  <view wx:if="{{!hasMore && shows.length > 0}}" class="status">没有更多了</view>

  <!-- 城市选择 -->
  <view wx:if="{{cityPickerOpen}}" class="city-picker">
    <view class="city-picker-header">
      <input class="city-search-input" placeholder="搜索城市" value="{{citySearch}}" bindinput="onCitySearchInput" />
      <text class="cancel-btn" bindtap="closeCityPicker">取消</text>
    </view>
    <scroll-view scroll-y class="city-picker-body" scroll-with-animation>
      <view class="city-picker-scroll-inner">
        <view class="city-section-header">
          <text class="filter-label">我的城市</text>
          <text class="done-btn" bindtap="closeCityPicker">完成</text>
        </view>
        <view class="city-chip-row">
          <text wx:if="{{cityNames.length === 0}}" class="filter-hint">还没有选择城市，不限则显示全部</text>
          <view wx:for="{{cityNames}}" wx:key="*this" class="chip">
            {{item}}
            <text class="chip-remove" data-name="{{item}}" catchtap="removeCity">✕</text>
          </view>
        </view>

        <block wx:for="{{cityGroups}}" wx:key="letter" wx:for-item="group">
          <view id="city-section-{{group.letter}}" class="city-letter">{{group.letter}}</view>
          <view
            wx:for="{{group.cities}}"
            wx:key="code"
            wx:for-item="city"
            class="city-row"
          >
            <text>{{city.name}}</text>
            <view
              class="city-plus {{cityNames.indexOf(city.name) > -1 ? 'city-plus-active' : ''}}"
              data-name="{{city.name}}"
              bindtap="toggleCity"
            >+</view>
          </view>
        </block>
      </view>
    </scroll-view>

    <view wx:if="{{!citySearch}}" class="letter-index">
      <text
        wx:for="{{cityGroups}}"
        wx:key="letter"
        class="letter-index-item"
        data-letter="{{item.letter}}"
        bindtap="jumpToLetter"
      >{{item.letter}}</text>
    </view>
  </view>
</view>
