@import '../index/index.wxss';

.page {
  padding: 40rpx 0 80rpx;
}

.page-padded {
  padding: 0 48rpx;
}

.tabs {
  display: flex;
  gap: 8rpx;
  background: #241C17;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 200rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 44rpx;
}

.tab {
  font-size: 26rpx;
  padding: 16rpx 36rpx;
  border-radius: 200rpx;
  color: #F2ECE1;
  font-weight: 600;
}

.tab-active {
  background: #C4472E;
  color: #FFFFFF;
}

.add-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.add-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 28rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #241C17;
  font-size: 32rpx;
  color: #F2ECE1;
}

.add-btn {
  flex-shrink: 0;
  height: 76rpx;
  padding: 0 36rpx;
  line-height: 76rpx;
  background: #B8862E;
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 20rpx;
}

.suggestions {
  position: relative;
  margin-top: 12rpx;
  z-index: 10;
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  box-shadow: 0 28rpx 60rpx rgba(42, 35, 32, 0.25);
  max-height: 520rpx;
  overflow-y: auto;
}

.suggestion-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #F2ECE1;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.14);
}

.hint {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-top: 12rpx;
}

.artist-list {
  margin-top: 32rpx;
}

.status {
  display: block;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: rgba(242, 236, 225, 0.62);
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #2A211C;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 28rpx 32rpx;
}

.list-row-text {
  font-size: 28rpx;
  color: #F2ECE1;
}

.list-star {
  color: #B8862E;
}

.remove-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 8rpx 20rpx;
  border-radius: 200rpx;
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-top: 64rpx;
}
