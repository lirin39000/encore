.page {
  padding-bottom: 40rpx;
}

.topbar {
  padding: 24rpx 24rpx 0;
}

.search-input {
  box-sizing: border-box;
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 28rpx;
  color: #F2ECE1;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.pill {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #2A211C;
  color: #F2ECE1;
}

.pill-active {
  background: #C4472E;
  border-color: #C4472E;
  color: #FFFFFF;
}

.city-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
}

.chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  padding: 8rpx 12rpx 8rpx 20rpx;
  border-radius: 16rpx;
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: #F2ECE1;
}

.chip-remove {
  color: rgba(242, 236, 225, 0.62);
  padding: 0 6rpx;
}

.status {
  display: block;
  padding: 80rpx 0;
  text-align: center;
  color: rgba(242, 236, 225, 0.62);
  font-size: 26rpx;
}

.card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.poster {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #2A211C;
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #F2ECE1;
}

.heart {
  flex-shrink: 0;
  font-size: 36rpx;
  color: rgba(242, 236, 225, 0.5);
  line-height: 1;
  padding: 4rpx;
}

.heart-active {
  color: #C4472E;
}

.sub {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.75);
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E0664A;
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 80vh;
  box-sizing: border-box;
  background: #1B1512;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.sheet-title {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  margin: 24rpx 0 16rpx;
}

.add-city-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: #C4472E;
  color: #FFFFFF;
}

.weekday-row {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.weekday-circle {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #2A211C;
  color: #F2ECE1;
}

.weekday-active {
  background: #C4472E;
  border-color: #C4472E;
  color: #FFFFFF;
}

.confirm-btn {
  margin-top: 32rpx;
  background: #C4472E;
  color: #FFFFFF;
  font-size: 28rpx;
}

.city-picker {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: #1B1512;
  display: flex;
  flex-direction: column;
}

.city-picker-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
}

.cancel-btn {
  flex-shrink: 0;
  font-size: 26rpx;
  color: rgba(242, 236, 225, 0.62);
}

.city-picker-body {
  flex: 1;
  padding: 0 24rpx;
}

.city-letter {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(242, 236, 225, 0.62);
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.city-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #F2ECE1;
}

.city-check {
  color: #C4472E;
  font-weight: 700;
}
