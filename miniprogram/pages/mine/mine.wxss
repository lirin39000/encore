.page {
  padding: 24rpx 24rpx 60rpx;
}

.tabs {
  display: flex;
  gap: 8rpx;
  background: #2A211C;
  border-radius: 100rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 32rpx;
}

.tab {
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 100rpx;
  color: #F2ECE1;
}

.tab-active {
  background: #C4472E;
  color: #FFFFFF;
}

.add-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.add-input {
  flex: 1;
  box-sizing: border-box;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 28rpx;
  color: #F2ECE1;
}

.add-btn {
  flex-shrink: 0;
  background: #B8862E;
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 0 28rpx;
  line-height: 1;
  height: auto;
}

.suggestions {
  background: #2A211C;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  margin-bottom: 16rpx;
  overflow: hidden;
}

.suggestion-item {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #F2ECE1;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.suggestion-item:last-child {
  border-bottom: none;
}

.hint {
  font-size: 22rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-bottom: 24rpx;
}

.status {
  display: block;
  padding: 60rpx 0;
  text-align: center;
  color: rgba(242, 236, 225, 0.62);
  font-size: 26rpx;
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: #2A211C;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.list-row-text {
  font-size: 26rpx;
  color: #F2ECE1;
}

.remove-btn {
  flex-shrink: 0;
  font-size: 22rpx;
  color: rgba(242, 236, 225, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
}

.card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.12);
}

.poster {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #2A211C;
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #F2ECE1;
}

.sub {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.75);
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E0664A;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-top: 48rpx;
}
