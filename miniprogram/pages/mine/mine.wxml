<view class="page">
  <view class="page-padded">
    <view class="tabs">
      <view class="tab {{tab === 'artists' ? 'tab-active' : ''}}" data-tab="artists" bindtap="switchTab">关注艺人</view>
      <view class="tab {{tab === 'favorites' ? 'tab-active' : ''}}" data-tab="favorites" bindtap="switchTab">收藏的演出</view>
      <view class="tab {{tab === 'email' ? 'tab-active' : ''}}" data-tab="email" bindtap="switchTab">邮箱订阅</view>
    </view>
  </view>

  <view wx:if="{{tab === 'artists'}}" class="section page-padded">
    <view class="add-row">
      <input
        class="add-input"
        placeholder="搜索艺人名添加关注"
        value="{{addInput}}"
        bindinput="onAddInput"
        bindfocus="onAddInput"
      />
      <view class="add-btn" bindtap="addArtist">添加</view>
    </view>

    <view wx:if="{{showSuggestions && suggestions.length > 0}}" class="suggestions">
      <view wx:for="{{suggestions}}" wx:key="*this" class="suggestion-item" data-name="{{item}}" bindtap="addArtist">
        {{item}}
      </view>
    </view>

    <view class="hint">输入后等待几秒输入框下方可能检索到相关乐队/艺人，也可以直接手动输入完整乐队/艺人名称添加（注意用官方名称，比如 Chinese Football 不能添加成"国足"，否则可能查找不成功）</view>

    <view class="artist-list">
      <view wx:if="{{loadingArtists && artists.length === 0}}" class="status">加载中...</view>
      <view wx:elif="{{!loadingArtists && artists.length === 0}}" class="status">还没有关注的艺人</view>
      <view wx:for="{{artists}}" wx:key="_id" class="list-row">
        <view class="list-row-text"><text class="list-star">★</text> {{item.artist_name}}</view>
        <view class="remove-btn" data-id="{{item._id}}" bindtap="removeArtist">移除</view>
      </view>
    </view>
  </view>

  <view wx:if="{{tab === 'favorites'}}">
    <view wx:if="{{loadingFavorites && favorites.length === 0}}" class="status page-padded">加载中...</view>
    <view wx:elif="{{!loadingFavorites && favorites.length === 0}}" class="status page-padded">还没有收藏的演出</view>

    <view wx:for="{{favorites}}" wx:key="_id" class="card">
      <view class="card-blur" style="background-image:{{item.posterBg}};"></view>
      <view class="card-overlay"></view>

      <view class="card-info">
        <view class="card-title">{{item.title}}</view>
        <view class="card-row">
          <text class="card-star">★</text>
          <text class="card-performers">{{item.performersText}}</text>
        </view>
        <view class="card-sub">{{item.showTimeText}}</view>
        <view class="card-sub">{{item.site_name}} · {{item.city_name}}</view>
        <view class="card-bottom-row">
          <text class="card-price">{{item.price}}</text>
          <text class="card-detail-link" data-id="{{item.id}}" catchtap="copyDetailLink">查看详情 →</text>
        </view>
      </view>

      <view
        class="card-poster"
        style="background-image:{{item.posterBg}};"
        data-url="{{item.poster_url}}"
        bindtap="previewPoster"
      >
        <view wx:if="{{item.sold_out === 2}}" class="sold-out-badge">已售罄</view>
        <view class="heart-btn" data-show="{{item}}" catchtap="toggleFavorite">
          <image class="heart-icon" src="{{item.heartIcon}}" />
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{tab === 'email'}}" class="section page-padded">
    <view class="sub-card">
      <view class="sub-title">演出上新邮件提醒</view>
      <view class="sub-desc">「关注艺人」里的艺人有新演出时，给你发一封邮件。每天最多一封，随时可以退订。</view>

      <view wx:if="{{loadingSub && !subLoaded}}" class="status">加载中...</view>

      <block wx:elif="{{!sub || editingEmail}}">
        <view class="add-row">
          <input
            class="add-input"
            type="text"
            placeholder="你的邮箱地址"
            value="{{emailInput}}"
            bindinput="onEmailInput"
          />
          <view class="add-btn {{submitting ? 'add-btn-disabled' : ''}}" bindtap="submitEmail">
            {{submitting ? '发送中' : '订阅'}}
          </view>
        </view>
        <view wx:if="{{editingEmail}}" class="sub-actions">
          <view class="sub-btn" bindtap="cancelEditEmail">取消</view>
        </view>
      </block>

      <block wx:else>
        <view class="sub-email-row">
          <view class="sub-email">
            {{sub.email}}
            <text wx:if="{{!sub.verified}}" class="sub-pending">待验证</text>
          </view>
          <view wx:if="{{!sub.verified}}" class="sub-btn sub-btn-primary" bindtap="refreshVerifyStatus">{{refreshing ? '更新中…' : '更新状态'}}</view>
        </view>
        <view class="sub-actions">
          <view wx:if="{{!sub.verified}}" class="sub-btn" bindtap="resendVerify">重新发送</view>
          <view class="sub-btn" bindtap="startEditEmail">更换邮箱</view>
          <view class="sub-btn" bindtap="cancelSubscription">取消订阅</view>
        </view>
        <view wx:if="{{!sub.verified}}" class="sub-desc sub-desc-tight">
          验证邮件已发到 {{sub.email}}，点开里面的链接后回来点"更新状态"。没收到看一下垃圾邮件。
        </view>
      </block>
    </view>
  </view>

  <view class="page-padded">
    <view class="footer">有问题或建议欢迎反馈至 lirin3900@gmail.com ╮(╯▽╰)╭</view>
  </view>
</view>
