@import '../index/index.wxss';

.page {
  padding: 40rpx 0 80rpx;
}

.page-padded {
  padding: 0 48rpx;
}

.tabs {
  display: flex;
  gap: 8rpx;
  background: #241C17;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 200rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 44rpx;
}

.tab {
  font-size: 26rpx;
  padding: 16rpx 36rpx;
  border-radius: 200rpx;
  color: #F2ECE1;
  font-weight: 600;
}

.tab-active {
  background: #C4472E;
  color: #FFFFFF;
}

.add-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.add-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 28rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #241C17;
  font-size: 32rpx;
  color: #F2ECE1;
}

.add-btn {
  flex-shrink: 0;
  height: 76rpx;
  padding: 0 36rpx;
  line-height: 76rpx;
  background: #B8862E;
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 20rpx;
}

.suggestions {
  position: relative;
  margin-top: 12rpx;
  z-index: 10;
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  box-shadow: 0 28rpx 60rpx rgba(42, 35, 32, 0.25);
  max-height: 520rpx;
  overflow-y: auto;
}

.suggestion-item {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #F2ECE1;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.14);
}

.hint {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-top: 12rpx;
}

.artist-list {
  margin-top: 32rpx;
}

.status {
  display: block;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: rgba(242, 236, 225, 0.62);
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #2A211C;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 28rpx 32rpx;
}

.list-row-text {
  font-size: 28rpx;
  color: #F2ECE1;
}

.list-star {
  color: #B8862E;
}

.remove-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 8rpx 20rpx;
  border-radius: 200rpx;
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  margin-top: 64rpx;
}

/* ---------- 邮箱订阅 ---------- */

.sub-card {
  background: #2A211C;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 28rpx;
  padding: 36rpx 36rpx 40rpx;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #F2ECE1;
}

.sub-desc {
  font-size: 26rpx;
  color: rgba(242, 236, 225, 0.62);
  line-height: 1.7;
  margin: 16rpx 0 28rpx;
}

.sub-desc-tight {
  margin: 24rpx 0 0;
}

/* 邮箱地址和"更新状态"按钮同一行：邮箱占左侧剩余空间，按钮靠右不压缩 */
.sub-email-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.sub-email {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #F2ECE1;
  word-break: break-all;
}

.sub-pending {
  font-size: 24rpx;
  color: #B8862E;
  margin-left: 16rpx;
}

.sub-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-top: 24rpx;
}

.sub-btn {
  font-size: 24rpx;
  color: rgba(242, 236, 225, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  /* 点击区域放大、间距拉开，减少误触到旁边"取消订阅"的概率 */
  padding: 16rpx 30rpx;
  border-radius: 200rpx;
}

/* "我已验证，刷新"是待验证状态下的主动作，用主色填充，跟其他次要按钮区分开 */
.sub-btn-primary {
  color: #FFFFFF;
  background: #C4472E;
  border-color: #C4472E;
}

/* 订阅按钮直接复用 .add-btn(金色)，跟"添加艺人"保持一致；这个类只管禁用时的变灰 */
.add-btn-disabled {
  opacity: 0.6;
}

